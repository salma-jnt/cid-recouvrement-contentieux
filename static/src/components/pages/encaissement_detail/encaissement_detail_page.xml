<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

<t t-name="recouvrement_contentieux.EncaissementDetailPage">
    <div class="cid-page cid-enc-detail-page">

        <!-- ── Skeleton ───────────────────────────────────────── -->
        <t t-if="state.loading">
            <CidSkeleton width="'100%'" height="'80px'"/>
            <div style="height:12px;"/>
            <CidSkeleton width="'100%'" height="'120px'"/>
            <div style="height:12px;"/>
            <CidSkeleton width="'100%'" height="'300px'"/>
        </t>

        <t t-elif="state.enc">

            <!-- ── Header ─────────────────────────────────────── -->
            <header class="cid-page__header cid-enc-detail-page__header">
                <div>
                    <CidButton variant="'ghost'" icon="'fa-arrow-left'"
                               size="'sm'" onClick="() => this.onBack()">
                        Retour aux encaissements
                    </CidButton>
                    <div class="cid-enc-detail-page__title-row">
                        <h1 class="cid-page__title" t-esc="state.enc.name"/>
                        <CidBadge variant="etatVariant" subtle="false">
                            <t t-esc="etatLabel"/>
                        </CidBadge>
                    </div>
                    <p class="cid-page__subtitle">
                        <i class="fa fa-user-circle"/>
                        <t t-esc="state.enc.client_id[1] || '—'"/>
                        <span class="cid-page__subtitle-sep">·</span>
                        <i class="fa fa-calendar-o"/>
                        <t t-esc="fmtDate(state.enc.date_operation)"/>
                        <span t-if="state.enc.recouvrement_id" class="cid-page__subtitle-sep">·</span>
                        <span t-if="state.enc.recouvrement_id">
                            <i class="fa fa-folder-open-o"/>
                            <t t-esc="state.enc.recouvrement_id[1]"/>
                        </span>
                    </p>
                </div>
                <div class="cid-enc-detail-page__header-actions">
                    <CidButton variant="'ghost'" icon="'fa-refresh'"
                               onClick="() => this.loadData()">
                        Actualiser
                    </CidButton>
                </div>
            </header>

            <!-- ── KPI Cards ──────────────────────────────────── -->
            <div class="cid-enc-detail-page__kpis">
                <CidKpiCard accent="'primary'" icon="'fa-money'"
                            label="'Montant total'"
                            value="fmt(state.enc.montant) + ' ' + state.enc.currency"/>
                <CidKpiCard accent="'success'" icon="'fa-check-circle'"
                            label="'Montant alloué'"
                            value="fmt(state.enc.montant_alloue) + ' ' + state.enc.currency"/>
                <CidKpiCard accent="'danger'" icon="'fa-exclamation-circle'"
                            label="'Reste à allouer'"
                            value="fmt(state.enc.reste_a_allouer) + ' ' + state.enc.currency"/>
                <CidKpiCard accent="'mauve'" icon="'fa-gavel'"
                            label="'Pénalité'"
                            value="fmt(state.enc.penalite || 0) + ' ' + state.enc.currency"/>
            </div>

            <!-- ── Corps : Infos + Lettrage ───────────────────── -->
            <div class="cid-enc-detail-page__grid">

                <!-- Colonne gauche : informations -->
                <div class="cid-enc-detail-page__left">

                    <!-- Infos identification -->
                    <CidCard padded="true">
                        <t t-set-slot="header">
                            <span><i class="fa fa-info-circle"/> Identification</span>
                        </t>
                        <div class="cid-enc-detail-page__info-grid">
                            <div class="cid-enc-detail-page__info-row">
                                <span class="cid-enc-detail-page__info-label">Client</span>
                                <span class="cid-enc-detail-page__info-value">
                                    <i class="fa fa-user-circle"/>
                                    <t t-esc="state.enc.client_id[1] || '—'"/>
                                </span>
                            </div>
                            <div class="cid-enc-detail-page__info-row">
                                <span class="cid-enc-detail-page__info-label">Code affaire</span>
                                <span class="cid-enc-detail-page__info-value"
                                      t-esc="state.enc.code_affaire || '—'"/>
                            </div>
                            <div class="cid-enc-detail-page__info-row">
                                <span class="cid-enc-detail-page__info-label">Mode de paiement</span>
                                <span class="cid-enc-detail-page__info-value"
                                      t-esc="modeLabel"/>
                            </div>
                            <div class="cid-enc-detail-page__info-row">
                                <span class="cid-enc-detail-page__info-label">Banque</span>
                                <span class="cid-enc-detail-page__info-value"
                                      t-esc="state.enc.banque || '—'"/>
                            </div>
                            <div class="cid-enc-detail-page__info-row">
                                <span class="cid-enc-detail-page__info-label">Pôle</span>
                                <span class="cid-enc-detail-page__info-value"
                                      t-esc="state.enc.pole_id ? state.enc.pole_id[1] : '—'"/>
                            </div>
                            <div t-if="state.enc.observation"
                                 class="cid-enc-detail-page__info-row cid-enc-detail-page__info-row--full">
                                <span class="cid-enc-detail-page__info-label">Observation</span>
                                <span class="cid-enc-detail-page__info-value"
                                      t-esc="state.enc.observation"/>
                            </div>
                        </div>
                    </CidCard>

                    <!-- Lettrages existants -->
                    <CidCard padded="false">
                        <t t-set-slot="header">
                            <span><i class="fa fa-link"/> Lettrages effectués</span>
                            <CidBadge variant="'neutral'" subtle="true" size="'sm'">
                                <t t-esc="state.lettrages.length"/>
                            </CidBadge>
                        </t>
                        <t t-if="state.lettrages.length === 0">
                            <div class="cid-enc-detail-page__empty-lettrages">
                                <i class="fa fa-inbox"/> Aucun lettrage effectué
                            </div>
                        </t>
                        <t t-else="">
                            <table class="cid-table cid-enc-detail-page__lettrage-table">
                                <thead>
                                    <tr>
                                        <th>Facture</th>
                                        <th class="cid-table__num">Montant affecté</th>
                                        <th>Date</th>
                                        <th class="cid-table__actions"/>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.lettrages" t-as="l" t-key="l.id">
                                        <tr>
                                            <td><strong t-esc="l.facture_id[1] || '—'"/></td>
                                            <td class="cid-table__num text-success">
                                                <strong t-esc="fmt(l.montant_affecte)"/>
                                                <span class="text-muted"> MAD</span>
                                            </td>
                                            <td class="text-muted" t-esc="fmtDate(l.date_lettrage)"/>
                                            <td class="cid-table__actions">
                                                <button class="cid-icon-btn cid-icon-btn--danger"
                                                        title="Supprimer"
                                                        t-on-click="() => this.onDeleteLettrage(l.id)">
                                                    <i class="fa fa-trash"/>
                                                </button>
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>
                        </t>
                    </CidCard>

                </div>

                <!-- Colonne droite : lettrage dynamique -->
                <div class="cid-enc-detail-page__right">
                    <CidCard padded="true" accentBar="'primary'">
                        <t t-set-slot="header">
                            <span><i class="fa fa-magic"/> Lettrage dynamique</span>
                        </t>

                        <!-- Compteur Reste à allouer -->
                        <div class="cid-enc-detail-page__reste-bar">
                            <div class="cid-enc-detail-page__reste-label">
                                Reste à allouer
                            </div>
                            <div t-att-class="'cid-enc-detail-page__reste-value ' + resteClass">
                                <t t-esc="fmt(resteEnCours)"/>
                                <span class="cid-enc-detail-page__reste-currency"
                                      t-esc="' ' + state.enc.currency"/>
                            </div>
                            <div class="cid-enc-detail-page__reste-progress">
                                <div class="cid-enc-detail-page__reste-track">
                                    <div class="cid-enc-detail-page__reste-fill"
                                         t-att-style="'width:' + Math.min(100, Math.round((1 - resteEnCours / (state.enc.montant || 1)) * 100)) + '%'"/>
                                </div>
                                <span class="text-muted" style="font-size:11px;">
                                    <t t-esc="Math.round((1 - resteEnCours / (state.enc.montant || 1)) * 100)"/>% alloué
                                </span>
                            </div>
                        </div>

                        <!-- Message si tout alloué -->
                        <div t-if="state.enc.reste_a_allouer === 0"
                             class="cid-enc-detail-page__solde-msg">
                            <i class="fa fa-check-circle text-success"/>
                            Cet encaissement est entièrement lettré.
                        </div>

                        <!-- Factures disponibles -->
                        <t t-elif="state.factures.length === 0">
                            <div class="cid-enc-detail-page__no-factures">
                                <i class="fa fa-file-text-o"/>
                                Aucune facture non soldée pour ce client.
                            </div>
                        </t>
                        <t t-else="">
                            <div class="cid-enc-detail-page__info-hint">
                                <i class="fa fa-info-circle"/>
                                Saisissez les montants à affecter par facture. Le système
                                empêche tout dépassement du reste à allouer ou du reste à payer.
                            </div>

                            <table class="cid-table cid-enc-detail-page__alloc-table">
                                <thead>
                                    <tr>
                                        <th>Facture</th>
                                        <th class="cid-table__num">TTC facture</th>
                                        <th class="cid-table__num">Reste à payer</th>
                                        <th class="cid-table__num">Montant à affecter</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <t t-foreach="state.factures" t-as="f" t-key="f.id">
                                        <tr>
                                            <td>
                                                <div class="cid-enc-detail-page__facture-cell">
                                                    <CidStatusPill color="f.statut_interface"
                                                                   withDot="true">
                                                        <t t-esc="f.statut_interface"/>
                                                    </CidStatusPill>
                                                    <div>
                                                        <strong t-esc="f.name"/>
                                                        <div class="text-muted"
                                                             style="font-size:11px;"
                                                             t-esc="f.code_affaire || '—'"/>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="cid-table__num text-muted">
                                                <t t-esc="fmt(f.montant_ttc)"/>
                                            </td>
                                            <td class="cid-table__num">
                                                <strong t-att-class="f.reste_a_payer > 0 ? 'text-danger' : 'text-success'">
                                                    <t t-esc="fmt(f.reste_a_payer)"/>
                                                </strong>
                                            </td>
                                            <td class="cid-table__num">
                                                <input
                                                    type="number"
                                                    class="cid-enc-detail-page__alloc-input"
                                                    min="0"
                                                    t-att-max="f.reste_a_payer"
                                                    t-att-placeholder="'0.00'"
                                                    t-att-value="state.allocations[f.id] || ''"
                                                    t-on-input="(ev) => this.onAllocationInput(f.id, ev)"
                                                />
                                            </td>
                                        </tr>
                                    </t>
                                </tbody>
                            </table>

                            <!-- Actions lettrage -->
                            <div class="cid-enc-detail-page__alloc-actions">
                                <CidButton variant="'secondary'" icon="'fa-magic'"
                                           loading="state.autoAllouing"
                                           onClick="() => this.onAutoFifo()">
                                    Auto-allouer (FIFO)
                                </CidButton>
                                <CidButton variant="'primary'" icon="'fa-check'"
                                           loading="state.saving"
                                           disabled="!canSave"
                                           onClick="() => this.onSaveLettrage()">
                                    Valider le lettrage
                                </CidButton>
                            </div>
                        </t>

                    </CidCard>
                </div>

            </div>
        </t>

    </div>
</t>

</templates>
