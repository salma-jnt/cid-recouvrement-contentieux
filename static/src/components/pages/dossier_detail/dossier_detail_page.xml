<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <t t-name="recouvrement_contentieux.DossierDetailPage">
        <div class="cid-page cid-dossier-page">

            <!-- Loading -->
            <t t-if="state.loading">
                <CidSkeleton width="'100%'" height="'80px'"/>
                <div style="height: 16px;"/>
                <CidSkeleton width="'100%'" height="'120px'"/>
                <div style="height: 16px;"/>
                <CidSkeleton width="'100%'" height="'200px'"/>
            </t>

            <t t-elif="state.dossier">
                <!-- Header -->
                <header class="cid-page__header">
                    <div>
                        <CidButton variant="'ghost'" icon="'fa-arrow-left'"
                                   onClick="() => this.onBack()" size="'sm'">
                            Retour aux dossiers
                        </CidButton>
                        <h1 class="cid-page__title" style="margin-top: 12px;">
                            <t t-esc="state.dossier.name"/>
                        </h1>
                        <div class="cid-dossier-page__meta">
                            <CidBadge variant="statePill.color" subtle="false">
                                <t t-esc="statePill.label"/>
                            </CidBadge>
                            <span class="cid-dossier-page__sep">·</span>
                            <span><i class="fa fa-sitemap"/> <t t-esc="state.dossier.procedure_name"/></span>
                            <span class="cid-dossier-page__sep">·</span>
                            <span><i class="fa fa-calendar-o"/> Dépôt : <t t-esc="fmtDate(state.dossier.date_depot_groupe)"/></span>
                        </div>
                    </div>
                </header>

                <!-- KPIs -->
                <div class="cid-dossier-page__kpis">
                    <CidKpiCard accent="'primary'" icon="'fa-files-o'"
                                label="'Factures'"
                                value="state.dossier.nombre_factures"/>
                    <CidKpiCard accent="'mauve'" icon="'fa-users'"
                                label="'Clients'"
                                value="state.dossier.nombre_clients"/>
                    <CidKpiCard accent="'accent'" icon="'fa-money'"
                                label="'Montant TTC'"
                                value="fmt(state.dossier.montant_ttc) + ' ' + state.dossier.currency"/>
                    <CidKpiCard accent="'success'" icon="'fa-check-circle'"
                                label="'Encaissé'"
                                value="fmt(state.dossier.montant_encaisse)"/>
                    <CidKpiCard accent="'danger'" icon="'fa-exclamation-circle'"
                                label="'Reste à recouvrer'"
                                value="fmt(state.dossier.reste_a_recouvrer)"/>
                </div>

                <!-- Stepper de phases -->
                <CidCard padded="true">
                    <t t-set-slot="header">
                        <span><i class="fa fa-flag"/> Phases de la procédure</span>
                        <span class="cid-dossier-page__phase-current">
                            Phase courante : <strong t-esc="state.dossier.phase_courante"/>
                        </span>
                    </t>
                    <CidStepper steps="state.phases"
                                currentIndex="currentPhaseIndex"
                                orientation="'horizontal'"/>
                </CidCard>

                <!-- Tabs -->
                <div class="cid-tabs">
                    <button t-att-class="'cid-tabs__item' + (state.activeTab === 'factures' ? ' is-active' : '')"
                            t-on-click="() => this.onTab('factures')">
                        <i class="fa fa-file-text-o"/> Factures
                        <span class="cid-tabs__count" t-esc="state.dossier.nombre_factures"/>
                    </button>
                    <button t-att-class="'cid-tabs__item' + (state.activeTab === 'actions' ? ' is-active' : '')"
                            t-on-click="() => this.onTab('actions')">
                        <i class="fa fa-tasks"/> Actions
                        <span class="cid-tabs__count" t-esc="state.actions.length"/>
                    </button>
                </div>

                <!-- Tab content : Factures groupées par client -->
                <t t-if="state.activeTab === 'factures'">
                    <div class="cid-dossier-page__client-groups">
                        <t t-foreach="state.factures" t-as="group" t-key="group.client_id">
                            <CidCard padded="false">
                                <t t-set-slot="header">
                                    <div class="cid-client-group__header">
                                        <div>
                                            <i class="fa fa-user-circle"/>
                                            <strong t-esc="group.client_name"/>
                                            <CidBadge variant="'neutral'" subtle="true" size="'sm'">
                                                <t t-esc="group.factures.length"/>
                                                facture<t t-if="group.factures.length &gt; 1">s</t>
                                            </CidBadge>
                                        </div>
                                        <div class="cid-client-group__totals">
                                            <span>TTC : <strong><t t-esc="fmt(group.total)"/></strong></span>
                                            <span>·</span>
                                            <span>Reste : <strong t-att-class="group.reste &gt; 0 ? 'text-danger' : 'text-success'"><t t-esc="fmt(group.reste)"/></strong></span>
                                            <span>·</span>
                                            <button class="cid-client-group__action-btn"
                                                    t-on-click="() => this.openClientDrawer(group)">
                                                <i class="fa fa-bolt"/> Agir
                                            </button>
                                        </div>
                                    </div>
                                </t>
                                <table class="cid-table">
                                    <thead>
                                        <tr>
                                            <th>Statut</th>
                                            <th>N° facture</th>
                                            <th>Code affaire</th>
                                            <th>Date</th>
                                            <th class="cid-table__num">TTC</th>
                                            <th class="cid-table__num">Payé</th>
                                            <th class="cid-table__num">Reste</th>
                                            <th class="cid-table__actions"></th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <t t-foreach="group.factures" t-as="f" t-key="f.id">
                                            <tr>
                                                <td>
                                                    <CidStatusPill color="f.statut_interface" withDot="true">
                                                        <t t-esc="f.statut_interface"/>
                                                    </CidStatusPill>
                                                </td>
                                                <td><strong t-esc="f.name"/></td>
                                                <td class="text-muted" t-esc="f.code_affaire || '—'"/>
                                                <td t-esc="fmtDate(f.date_facture)"/>
                                                <td class="cid-table__num" t-esc="fmt(f.montant_ttc)"/>
                                                <td class="cid-table__num text-muted" t-esc="fmt(f.montant_paye)"/>
                                                <td class="cid-table__num">
                                                    <strong t-att-class="f.reste_a_payer &gt; 0 ? 'text-danger' : 'text-success'"
                                                            t-esc="fmt(f.reste_a_payer)"/>
                                                </td>
                                                <td class="cid-table__actions">
                                                    <!-- Action contextuelle : ouvrir l'action courante de cette facture -->
                                                </td>
                                            </tr>
                                        </t>
                                    </tbody>
                                </table>
                            </CidCard>
                        </t>
                    </div>
                </t>

                <!-- Tab content : Actions list -->
                <t t-if="state.activeTab === 'actions'">
                    <CidCard padded="false">
                        <table class="cid-table">
                            <thead>
                                <tr>
                                    <th>Type</th>
                                    <th>Action</th>
                                    <th>Client</th>
                                    <th>Échéance</th>
                                    <th>Statut</th>
                                    <th>Responsable</th>
                                    <th class="cid-table__actions">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-foreach="state.actions" t-as="a" t-key="a.id">
                                    <tr t-att-class="a.is_overdue and a.state !== 'done' ? 'cid-row-overdue' : ''">
                                        <td>
                                            <span class="cid-type-cell">
                                                <i t-att-class="'fa ' + actionTypeIcon(a.action_type)"/>
                                                <t t-esc="actionTypeLabel(a.action_type)"/>
                                            </span>
                                        </td>
                                        <td t-esc="a.name"/>
                                        <td class="text-muted">
                                            <t t-if="a.client_id" t-esc="a.client_id[1]"/>
                                            <t t-else="">—</t>
                                        </td>
                                        <td t-esc="fmtDate(a.mandatory_date)"/>
                                        <td>
                                            <CidBadge t-if="a.state === 'done'" variant="'success'" subtle="true">Réalisée</CidBadge>
                                            <CidBadge t-elif="a.state === 'reporte'" variant="'warning'" subtle="true">Reportée</CidBadge>
                                            <CidBadge t-elif="a.state === 'cancel'" variant="'neutral'" subtle="true">Annulée</CidBadge>
                                            <CidBadge t-else="" variant="'info'" subtle="true">À faire</CidBadge>
                                        </td>
                                        <td class="text-muted">
                                            <t t-if="a.responsible_id" t-esc="a.responsible_id[1]"/>
                                        </td>
                                        <td class="cid-table__actions">
                                            <!-- Boutons uniquement sur la DERNIÈRE action active du client -->
                                            <!-- (la plus récente todo/reportée — calculée dans activeActionIds) -->
                                            <CidButton t-if="state.activeActionIds and state.activeActionIds.has(a.id)"
                                                       variant="'primary'" size="'sm'"
                                                       icon="'fa-bolt'"
                                                       onClick="() => this.onActionClick(a)">
                                                Exécuter
                                            </CidButton>
                                            <CidButton t-if="state.activeActionIds and state.activeActionIds.has(a.id)"
                                                       variant="'ghost'" size="'sm'"
                                                       icon="'fa-clock-o'"
                                                       onClick="() => this.onActionReport(a)">
                                                Reporter
                                            </CidButton>
                                        </td>
                                    </tr>
                                </t>
                            </tbody>
                        </table>
                    </CidCard>
                </t>
            </t>
        <!-- ── Drawer client (CidDrawer réutilisable) ───────────────── -->
        <CidDrawer isOpen="!!state.drawer"
                   title="state.drawer ? state.drawer.group.client_name : ''"
                   subtitle="state.drawer ? (state.drawer.group.city || '') : ''"
                   size="'md'"
                   onClose="() => this.closeDrawer()">

            <!-- Badge statut action dans le header -->
            <t t-set-slot="header-extra">
                <t t-if="state.drawer and state.drawer.action">
                    <CidBadge t-if="state.drawer.action.state === 'reporte'"
                              variant="'warning'" subtle="true">Reportée</CidBadge>
                    <CidBadge t-else="" variant="'info'" subtle="true">À faire</CidBadge>
                </t>
                <t t-elif="state.drawer">
                    <CidBadge variant="'success'" subtle="true">Tout réalisé</CidBadge>
                </t>
            </t>

            <!-- ── Corps du drawer ──────────────────────────────── -->

            <!-- Section 1 : Coordonnées client -->
            <CidDrawerSection title="'Coordonnées'" icon="'fa-user-circle'">
                <CidDrawerInfoRow icon="'fa-phone'"
                                  label="'Téléphone'"
                                  value="state.drawer ? (state.drawer.group.phone || '—') : ''"
                                  href="state.drawer and state.drawer.group.phone ? 'tel:' + state.drawer.group.phone : ''"/>
                <CidDrawerInfoRow icon="'fa-envelope-o'"
                                  label="'Email'"
                                  value="state.drawer ? (state.drawer.group.email || '—') : ''"
                                  href="state.drawer and state.drawer.group.email ? 'mailto:' + state.drawer.group.email : ''"/>
                <CidDrawerInfoRow icon="'fa-map-marker'"
                                  label="'Ville'"
                                  value="state.drawer ? (state.drawer.group.city || '—') : ''"/>
            </CidDrawerSection>

            <!-- Section 2 : Action en cours -->
            <CidDrawerSection title="'Action en cours'" icon="'fa-bolt'">
                <t t-if="state.drawer and state.drawer.action">
                    <!-- Carte action -->
                    <div class="cid-dossier-page__action-card">
                        <div class="cid-dossier-page__action-card-title">
                            <i t-att-class="'fa ' + actionTypeIcon(state.drawer.action.action_type)"/>
                            <span t-esc="state.drawer.action.name"/>
                        </div>
                        <div class="cid-dossier-page__action-card-meta">
                            <span>
                                <i class="fa fa-calendar-o"/>
                                Échéance : <strong t-esc="fmtDate(state.drawer.action.mandatory_date)"/>
                            </span>
                            <span t-if="state.drawer.action.responsible_id" class="text-muted">
                                <i class="fa fa-user-o"/>
                                <t t-esc="state.drawer.action.responsible_id[1]"/>
                            </span>
                        </div>
                    </div>
                </t>
                <t t-else="">
                    <div class="cid-dossier-page__no-action">
                        <i class="fa fa-check-circle"/> Aucune action en attente.
                    </div>
                </t>
            </CidDrawerSection>

            <!-- Section 3 : Factures du client dans ce dossier -->
            <CidDrawerSection title="'Factures'" icon="'fa-file-text-o'">
                <t t-if="state.drawer">
                    <t t-foreach="state.drawer.group.factures" t-as="f" t-key="f.id">
                        <div class="cid-dossier-page__drawer-facture">
                            <div class="cid-dossier-page__drawer-facture-left">
                                <CidStatusPill color="f.statut_interface" withDot="true">
                                    <t t-esc="f.statut_interface"/>
                                </CidStatusPill>
                                <div>
                                    <div class="cid-dossier-page__drawer-facture-name">
                                        <strong t-esc="f.name"/>
                                    </div>
                                    <div class="text-muted" style="font-size:12px;">
                                        <t t-esc="f.code_affaire || '—'"/>
                                        · <t t-esc="fmtDate(f.date_facture)"/>
                                    </div>
                                </div>
                            </div>
                            <div class="cid-dossier-page__drawer-facture-right">
                                <div class="text-muted" style="font-size:12px;">TTC</div>
                                <div><strong t-esc="fmt(f.montant_ttc)"/></div>
                                <div t-att-class="f.reste_a_payer > 0 ? 'text-danger' : 'text-success'"
                                     style="font-size:12px;">
                                    Reste <strong t-esc="fmt(f.reste_a_payer)"/>
                                </div>
                            </div>
                        </div>
                    </t>
                </t>
            </CidDrawerSection>

            <!-- ── Footer : boutons principaux ──────────────────── -->
            <t t-set-slot="footer">
                <t t-if="state.drawer and state.drawer.action">
                    <CidButton variant="'primary'" icon="'fa-bolt'"
                               onClick="() => this.drawerExecute()">
                        Exécuter
                    </CidButton>
                    <CidButton variant="'ghost'" icon="'fa-clock-o'"
                               onClick="() => this.drawerReport()">
                        Reporter
                    </CidButton>
                </t>
                <CidButton variant="'ghost'" icon="'fa-times'"
                           onClick="() => this.closeDrawer()">
                    Fermer
                </CidButton>
            </t>

        </CidDrawer>

        </div>
    </t>

</templates>