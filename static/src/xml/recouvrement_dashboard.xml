<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="recouvrement_contentieux.RecouvrementSidebar">
        <t t-if="isVisible">
            <aside class="o_recouvrement_floating_sidebar">
                <div class="o_recouvrement_sidebar_brand">
                    <div class="o_recouvrement_brand_title">Recouvrement</div>
                    <div class="o_recouvrement_brand_subtitle">Navigation rapide</div>
                </div>

                <t t-foreach="sections" t-as="section" t-key="section.title">
                    <div class="o_recouvrement_sidebar_section">
                        <div class="o_recouvrement_sidebar_section_title" t-esc="section.title"/>
                        <t t-foreach="section.items" t-as="item" t-key="item.actionXmlId">
                            <button type="button" class="o_recouvrement_nav_item" t-on-click="() => this.openAction(item.actionXmlId)">
                                <i t-att-class="`fa ${item.icon}`"/>
                                <span t-esc="item.label"/>
                            </button>
                        </t>
                    </div>
                </t>
            </aside>
        </t>
    </t>

    <t t-name="recouvrement_contentieux.RecouvrementDashboard">
        <div class="o_recouvrement_dashboard">
            <aside class="o_recouvrement_sidebar">
                <div class="o_recouvrement_sidebar_brand">
                    <div class="o_recouvrement_brand_title">Recouvrement</div>
                    <div class="o_recouvrement_brand_subtitle">Navigation rapide</div>
                </div>

                <t t-foreach="sections" t-as="section" t-key="section.title">
                    <div class="o_recouvrement_sidebar_section">
                        <div class="o_recouvrement_sidebar_section_title" t-esc="section.title"/>
                        <t t-foreach="section.items" t-as="item" t-key="item.actionXmlId">
                            <button type="button" class="o_recouvrement_nav_item" t-on-click="() => this.openAction(item.actionXmlId)">
                                <i t-att-class="`fa ${item.icon}`"/>
                                <span t-esc="item.label"/>
                            </button>
                        </t>
                    </div>
                </t>
            </aside>

            <section class="o_recouvrement_dashboard_content">
                <div class="o_recouvrement_hero_card">
                    <div>
                        <h1>Gestion des recouvrements</h1>
                        <p>Accédez rapidement aux factures, dossiers, actions et encaissements depuis cette barre latérale.</p>
                    </div>
                    <button type="button" class="btn btn-primary" t-on-click="() => this.openAction('recouvrement_contentieux.action_recouvrement_facture')">
                        Ouvrir les factures
                    </button>
                </div>

                <div class="o_recouvrement_shortcuts">
                    <button type="button" class="o_recouvrement_shortcut" t-on-click="() => this.openAction('recouvrement_contentieux.action_recouvrement_recouvrement')">
                        <i class="fa fa-folder-open-o"/>
                        <span>Dossiers de recouvrement</span>
                    </button>
                    <button type="button" class="o_recouvrement_shortcut" t-on-click="() => this.openAction('recouvrement_contentieux.action_recouvrement_action')">
                        <i class="fa fa-phone"/>
                        <span>Actions de recouvrement</span>
                    </button>
                    <button type="button" class="o_recouvrement_shortcut" t-on-click="() => this.openAction('recouvrement_contentieux.action_recouvrement_import_factures')">
                        <i class="fa fa-upload"/>
                        <span>Importer des factures</span>
                    </button>
                </div>
            </section>
        </div>
    </t>
</templates>
