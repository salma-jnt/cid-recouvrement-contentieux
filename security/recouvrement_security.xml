<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data noupdate="1">
        <record id="group_recouvrement_user" model="res.groups">
            <field name="name">Utilisateur Recouvrement</field>
        </record>

        <record id="group_recouvrement_manager" model="res.groups">
            <field name="name">Manager Recouvrement</field>
            <field name="implied_ids" eval="[(4, ref('group_recouvrement_user'))]"/>
        </record>
    </data>

    <data>
        <!-- Temporaire: donner les droits manager recouvrement a tous les utilisateurs internes. -->
        <record id="base.group_user" model="res.groups">
            <field name="implied_ids" eval="[(4, ref('recouvrement_contentieux.group_recouvrement_manager'))]"/>
        </record>
    </data>
</odoo>
