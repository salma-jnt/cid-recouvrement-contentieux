<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_recouvrement_facture_tree" model="ir.ui.view">
            <field name="name">recouvrement.facture.tree</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <list string="Factures">
                    <header>
                        <button name="%(recouvrement_contentieux.action_recouvrement_import_factures)d" type="action" string="Importer Excel" class="btn-primary" display="always"/>
                    </header>
                    <field name="name"/>
                    <field name="facture_type"/>
                    <field name="source_sheet"/>
                    <field name="client_id"/>
                    <field name="code_affaire"/>
                    <field name="date_facture"/>
                    <field name="date_depot_client"/>
                    <field name="montant_ttc"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_facture_form" model="ir.ui.view">
            <field name="name">recouvrement.facture.form</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <form string="Facture">
                    <header>
                        <button name="%(recouvrement_contentieux.action_recouvrement_import_factures)d" type="action" string="Importer Excel" class="btn-primary"/>
                    </header>
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="facture_type"/>
                            <field name="source_sheet" readonly="1"/>
                            <field name="client_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="date_reception_ordre"/>
                            <field name="date_facture"/>
                            <field name="date_signature"/>
                            <field name="date_depot_client"/>
                        </group>
                        <group>
                            <field name="chez_laila"/>
                            <field name="chez_bennis"/>
                            <field name="reference_justificatif"/>
                            <field name="depot_comment"/>
                        </group>
                        <group>
                            <field name="montant_ttc"/>
                            <field name="montant_ht"/>
                            <field name="division_id"/>
                            <field name="pole_id"/>
                        </group>
                        <group>
                            <field name="code_affaire"/>
                            <field name="numero_enreg"/>
                            <field name="ice"/>
                            <field name="numero_marche"/>
                        </group>
                        <group>
                            <field name="nature"/>
                            <field name="recouvrement_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_recouvrement_tree" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.tree</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <list string="Recouvrements">
                    <field name="name"/>
                    <field name="facture_id"/>
                    <field name="client_id"/>
                    <field name="procedure_id"/>
                    <field name="state"/>
                    <field name="next_action_date"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_recouvrement_form" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.form</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <form string="Dossier de recouvrement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="facture_id"/>
                            <field name="client_id" readonly="1"/>
                            <field name="procedure_id"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="date_depot_client"/>
                            <field name="montant_ttc" readonly="1"/>
                            <field name="montant_encaisse" readonly="1"/>
                            <field name="next_action_date" readonly="1"/>
                        </group>
                        <notebook>
                            <page string="Actions">
                                <field name="action_ids">
                                    <list editable="bottom">
                                        <field name="name"/>
                                        <field name="action_type"/>
                                        <field name="mandatory_date"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_action_tree" model="ir.ui.view">
            <field name="name">recouvrement.action.tree</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <list string="Actions de recouvrement">
                    <field name="name"/>
                    <field name="recouvrement_id"/>
                    <field name="action_type"/>
                    <field name="mandatory_date"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_action_form" model="ir.ui.view">
            <field name="name">recouvrement.action.form</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <form string="Action de recouvrement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="recouvrement_id"/>
                            <field name="action_type"/>
                            <field name="procedure_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="mandatory_date"/>
                            <field name="state"/>
                            <field name="date_done"/>
                        </group>
                        <group>
                            <field name="comment"/>
                        </group>
                        <footer>
                            <button name="action_done" type="object" string="Marquer réalisée" class="btn-primary"/>
                            <button name="action_reset" type="object" string="Réinitialiser" class="btn-secondary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_encaissement_tree" model="ir.ui.view">
            <field name="name">recouvrement.encaissement.tree</field>
            <field name="model">recouvrement.encaissement</field>
            <field name="arch" type="xml">
                <list string="Encaissements">
                    <field name="name"/>
                    <field name="facture_id"/>
                    <field name="recouvrement_id"/>
                    <field name="montant"/>
                    <field name="date_encaissement"/>
                    <field name="mode_paiement"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_encaissement_form" model="ir.ui.view">
            <field name="name">recouvrement.encaissement.form</field>
            <field name="model">recouvrement.encaissement</field>
            <field name="arch" type="xml">
                <form string="Encaissement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="facture_id"/>
                            <field name="recouvrement_id"/>
                        </group>
                        <group>
                            <field name="montant"/>
                            <field name="date_encaissement"/>
                            <field name="mode_paiement"/>
                            <field name="currency_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_procedure_tree" model="ir.ui.view">
            <field name="name">recouvrement.procedure.tree</field>
            <field name="model">recouvrement.procedure</field>
            <field name="arch" type="xml">
                <list string="Procédures de recouvrement">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="delay_appel"/>
                    <field name="delay_relance_1"/>
                    <field name="delay_relance_2"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_procedure_form" model="ir.ui.view">
            <field name="name">recouvrement.procedure.form</field>
            <field name="model">recouvrement.procedure</field>
            <field name="arch" type="xml">
                <form string="Procédure de recouvrement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="delay_appel"/>
                            <field name="delay_relance_1"/>
                            <field name="delay_relance_2"/>
                            <field name="delay_contentieux"/>
                        </group>
                        <notebook>
                            <page string="Modèles d’actions">
                                <field name="action_template_ids">
                                    <list editable="bottom">
                                        <field name="sequence"/>
                                        <field name="name"/>
                                        <field name="action_type"/>
                                        <field name="delay"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_action_template_tree" model="ir.ui.view">
            <field name="name">recouvrement.action.template.tree</field>
            <field name="model">recouvrement.action.template</field>
            <field name="arch" type="xml">
                <list string="Modèles d’actions">
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="procedure_id"/>
                    <field name="action_type"/>
                    <field name="delay"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_action_template_form" model="ir.ui.view">
            <field name="name">recouvrement.action.template.form</field>
            <field name="model">recouvrement.action.template</field>
            <field name="arch" type="xml">
                <form string="Modèle d’action">
                    <sheet>
                        <group>
                            <field name="procedure_id"/>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="action_type"/>
                            <field name="delay"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_client_type_tree" model="ir.ui.view">
            <field name="name">recouvrement.client.type.tree</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <list string="Types de clients">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="procedure_id"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_client_type_form" model="ir.ui.view">
            <field name="name">recouvrement.client.type.form</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <form string="Type de client">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="procedure_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="search_recouvrement_facture" model="ir.ui.view">
            <field name="name">recouvrement.facture.search</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="source_sheet"/>
                    <filter name="factures_standard" string="Standard" domain="[('facture_type','=','standard')]"/>
                    <filter name="factures_proforma" string="Proforma" domain="[('facture_type','=','proforma')]"/>
                    <filter name="factures_groupement" string="Groupement" domain="[('facture_type','=','groupement')]"/>
                    <filter name="factures_avance" string="Avances" domain="[('facture_type','=','avance')]"/>
                    <filter name="factures_autre" string="Autres" domain="[('facture_type','=','autre')]"/>
                    <separator/>
                    <filter name="feuille_groupement" string="Feuille Groupement" domain="[('source_sheet','ilike','GROUPEMENT')]"/>
                    <filter name="feuille_proforma" string="Feuille Proforma" domain="[('source_sheet','ilike','PRO-FORMA')]"/>
                    <filter name="feuille_avances" string="Feuille Avances" domain="[('source_sheet','ilike','AVANCES')]"/>
                    <separator/>
                    <filter name="group_by_type" string="Grouper par type" context="{'group_by': 'facture_type'}"/>
                    <filter name="group_by_sheet" string="Grouper par feuille" context="{'group_by': 'source_sheet'}"/>
                    <filter name="group_by_client" string="Grouper par client" context="{'group_by': 'client_id'}"/>
                </search>
            </field>
        </record>

        <record id="search_recouvrement_recouvrement" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.search</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="state"/>
                    <filter name="en_cours" string="En cours" domain="[('state','=','open')]"/>
                    <filter name="en_retard" string="En retard" domain="[('state','=','late')]"/>
                    <filter name="clotures" string="Clôturés" domain="[('state','=','closed')]"/>
                </search>
            </field>
        </record>

        <record id="search_recouvrement_action" model="ir.ui.view">
            <field name="name">recouvrement.action.search</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="recouvrement_id"/>
                    <field name="action_type"/>
                    <field name="state"/>
                    <filter name="aujourd_hui" string="Aujourd’hui" domain="[('mandatory_date','=', context_today())]"/>
                    <filter name="en_retard" string="En retard" domain="[('mandatory_date','&lt;', context_today()), ('state', '!=', 'done')]"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
