<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_recouvrement_facture_tree" model="ir.ui.view">
            <field name="name">recouvrement.facture.tree</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <list string="Factures" class="o_rcv_facture_list" decoration-info="recouvrement_status == 'precontentieux'" decoration-danger="recouvrement_status in ('contentieux', 'bloque')" decoration-success="recouvrement_status == 'recouvre'">
                    <field name="name"/>
                    <field name="code_affaire"/>
                    <field name="client_id"/>
                    <field name="division_id"/>
                    <field name="date_depot_client"/>
                    <field name="montant_ttc"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_facture_form" model="ir.ui.view">
            <field name="name">recouvrement.facture.form</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <form string="Facture" class="o_rcv_facture_form">
                    <sheet>
                        <div class="o_facture_header">
                            <div class="o_facture_identity">
                                <h2><field name="name" class="o_facture_number" placeholder="N° facture" readonly="1"/></h2>
                                <div class="o_facture_meta_line">
                                    <span class="o_facture_meta_label">Client :</span>
                                    <field name="client_id" readonly="1" class="o_facture_meta_value"/>
                                    <span class="o_facture_meta_sep">|</span>
                                    <span class="o_facture_meta_label">Code affaire :</span>
                                    <field name="code_affaire" readonly="1" class="o_facture_meta_value"/>
                                </div>
                            </div>
                        </div>

                        <div class="o_facture_tracker_card">
                            <div class="o_rcv_timeline">
                                <div class="o_rcv_tl_step o_active">
                                    <div class="o_rcv_tl_icon"><i class="fa fa-dot-circle-o" title="Normal"/></div>
                                    <div class="o_rcv_tl_title">NORMAL</div>
                                </div>
                                <div class="o_rcv_tl_line"/>
                                <div class="o_rcv_tl_step">
                                    <div class="o_rcv_tl_icon"><i class="fa fa-balance-scale" title="Précontentieux"/></div>
                                    <div class="o_rcv_tl_title">PRÉCONTENTIEUX</div>
                                </div>
                                <div class="o_rcv_tl_line"/>
                                <div class="o_rcv_tl_step">
                                    <div class="o_rcv_tl_icon"><i class="fa fa-gavel" title="Contentieux"/></div>
                                    <div class="o_rcv_tl_title">CONTENTIEUX</div>
                                </div>
                                <div class="o_rcv_tl_line"/>
                                <div class="o_rcv_tl_step">
                                    <div class="o_rcv_tl_icon"><i class="fa fa-check-circle-o" title="Clôturée"/></div>
                                    <div class="o_rcv_tl_title">RECOUVRÉE</div>
                                </div>
                            </div>
                        </div>

                        <group>
                            <group string="Informations générales" class="o_rcv_card_box">
                                <field name="client_id" readonly="1"/>
                                <field name="code_affaire" readonly="1"/>
                                <field name="numero_enreg" readonly="1"/>
                                <field name="date_reception_ordre" readonly="1"/>
                                <field name="date_signature" readonly="1"/>
                                <field name="date_depot_client" readonly="1"/>
                                <field name="date_echeance" readonly="1"/>
                            </group>
                            <group string="Informations financières" class="o_rcv_card_box">
                                <field name="montant_ht" readonly="1"/>
                                <field name="montant_ttc" readonly="1"/>
                            </group>
                        </group>
                        
                        <group>
                            <group string="Informations internes" class="o_rcv_card_box">
                                <field name="division_id" readonly="1"/>
                                <field name="pole_id" readonly="1"/>
                                <field name="ice" readonly="1"/>
                                <field name="numero_marche" readonly="1"/>
                            </group>
                            <group string="Informations administratives" class="o_rcv_card_box">
                                <field name="reference_justificatif" readonly="1"/>
                                <field name="depot_comment" readonly="1"/>
                                <field name="recouvrement_status" widget="badge" readonly="1"/>
                                <field name="recouvrement_id" readonly="1"/>
                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_recouvrement_tree" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.tree</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <list string="Recouvrements" class="o_recouvrement_compact_list">
                    <field name="name" string="N° Dossier"/>
                    <field name="date_echeance"/>
                    <field name="procedure_id"/>
                    <field name="phase_courante"/>
                    <field name="nb_factures"/>
                    <field name="montant_ttc"/>
                    <field name="reste_a_recouvrer"/>
                    <field name="state"/>
                    <field name="prochaine_action"/>
                    <field name="responsable_id"/>
                    <field name="create_date" string="Créé le"/>
                    <field name="client_id" optional="hide"/>
                    <field name="facture_ids" optional="hide"/>
                    <field name="motif_blocage" optional="hide"/>
                    <field name="prochaine_echeance" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_recouvrement_form" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.form</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <form string="Dossier de recouvrement">
                    <header>
                        <field name="state" widget="statusbar"/>
                        <button name="action_generate_actions" type="object" string="Générer actions" class="btn-primary" invisible="state == 'closed'"/>
                        <button name="action_mark_closed" type="object" string="Marquer recouvré" class="btn-secondary" invisible="state == 'closed'"/>
                        <field name="next_action_date"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="procedure_id"/>
                                <field name="phase_courante" readonly="1"/>
                                <field name="date_echeance"/>
                                <field name="prochaine_echeance" readonly="1"/>
                                <field name="motif_blocage" placeholder="Préciser le motif si le dossier est bloqué" invisible="state != 'blocked'"/>
                            </group>
                            <group>
                                <div class="o_form_label">Résumé</div>
                                <field name="montant_ttc" readonly="1"/>
                                <field name="montant_encaisse" readonly="1"/>
                                <field name="reste_a_recouvrer" readonly="1"/>
                                <field name="last_action_date" readonly="1"/>
                                <field name="next_action_date" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Factures regroupées">
                                <field name="facture_ids">
                                    <list string="Factures" editable="bottom">
                                        <field name="name" string="N° facture"/>
                                        <field name="client_id"/>
                                        <field name="montant_ttc"/>
                                        <field name="date_facture"/>
                                        <field name="depot_display" string="Dépôt client"/>
                                        <field name="recouvrement_status"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Actions">
                                <field name="action_ids">
                                    <list string="Actions" editable="bottom">
                                        <field name="name"/>
                                        <field name="responsible_id"/>
                                        <field name="action_type"/>
                                        <field name="mandatory_date"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Encaissements">
                                <field name="encaissement_ids">
                                    <list string="Encaissements" editable="bottom">
                                        <field name="name"/>
                                        <field name="montant"/>
                                        <field name="date_operation"/>
                                        <field name="banque"/>
                                    </list>
                                </field>
                            </page>
                            <page string="Historique">
                                <field name="action_ids" nolabel="1">
                                    <kanban>
                                        <templates>
                                            <t t-name="kanban-box">
                                                <div>
                                                    <strong t-esc="record.name.raw_value"/>
                                                    <div><t t-esc="record.mandatory_date.raw_value"/></div>
                                                    <div><t t-esc="record.state.raw_value"/></div>
                                                </div>
                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_action_tree" model="ir.ui.view">
            <field name="name">recouvrement.action.tree</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <list string="Actions de recouvrement">
                    <field name="name"/>
                    <field name="recouvrement_id"/>
                    <field name="responsible_id"/>
                    <field name="action_type"/>
                    <field name="priority"/>
                    <field name="mandatory_date"/>
                    <field name="date_done"/>
                    <field name="state"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_action_form" model="ir.ui.view">
            <field name="name">recouvrement.action.form</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <form string="Action de recouvrement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="recouvrement_id"/>
                            <field name="action_type"/>
                            <field name="procedure_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="responsible_id"/>
                            <field name="priority"/>
                            <field name="mandatory_date"/>
                        </group>
                        <group>
                            <field name="state"/>
                            <field name="date_done"/>
                            <field name="is_overdue" readonly="1"/>
                        </group>
                        <group>
                            <field name="comment"/>
                        </group>
                        <footer>
                            <button name="action_done" type="object" string="Marquer réalisée" class="btn-primary"/>
                            <button name="action_reset" type="object" string="Réinitialiser" class="btn-secondary"/>
                            <button name="action_cancel" type="object" string="Annuler" class="btn-secondary"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_encaissement_tree" model="ir.ui.view">
            <field name="name">recouvrement.encaissement.tree</field>
            <field name="model">recouvrement.encaissement</field>
            <field name="arch" type="xml">
                <list string="Encaissements">
                    <field name="pole_id"/>
                    <field name="code_affaire"/>
                    <field name="client_id"/>
                    <field name="montant"/>
                    <field name="penalite"/>
                    <field name="date_operation"/>
                    <field name="banque"/>
                    <field name="observation"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_encaissement_form" model="ir.ui.view">
            <field name="name">recouvrement.encaissement.form</field>
            <field name="model">recouvrement.encaissement</field>
            <field name="arch" type="xml">
                <form string="Encaissement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="facture_id"/>
                            <field name="recouvrement_id"/>
                            <field name="client_id"/>
                        </group>
                        <group>
                            <field name="pole_id"/>
                            <field name="code_affaire"/>
                            <field name="banque"/>
                            <field name="mode_paiement"/>
                        </group>
                        <group>
                            <field name="montant"/>
                            <field name="penalite"/>
                            <field name="date_operation"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="observation"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_procedure_tree" model="ir.ui.view">
            <field name="name">recouvrement.procedure.tree</field>
            <field name="model">recouvrement.procedure</field>
            <field name="arch" type="xml">
                <list string="Procédures de recouvrement">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="delay_appel"/>
                    <field name="delay_relance_1"/>
                    <field name="delay_relance_2"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_procedure_form" model="ir.ui.view">
            <field name="name">recouvrement.procedure.form</field>
            <field name="model">recouvrement.procedure</field>
            <field name="arch" type="xml">
                <form string="Procédure de recouvrement">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="description"/>
                        </group>
                        <group>
                            <field name="delay_appel"/>
                            <field name="delay_relance_1"/>
                            <field name="delay_relance_2"/>
                            <field name="delay_contentieux"/>
                        </group>
                        <notebook>
                            <page string="Modèles d’actions">
                                <field name="action_template_ids">
                                    <list editable="bottom">
                                        <field name="sequence"/>
                                        <field name="name"/>
                                        <field name="action_type"/>
                                        <field name="delay"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_action_template_tree" model="ir.ui.view">
            <field name="name">recouvrement.action.template.tree</field>
            <field name="model">recouvrement.action.template</field>
            <field name="arch" type="xml">
                <list string="Modèles d’actions">
                    <field name="sequence"/>
                    <field name="name"/>
                    <field name="procedure_id"/>
                    <field name="action_type"/>
                    <field name="delay"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_action_template_form" model="ir.ui.view">
            <field name="name">recouvrement.action.template.form</field>
            <field name="model">recouvrement.action.template</field>
            <field name="arch" type="xml">
                <form string="Modèle d’action">
                    <sheet>
                        <group>
                            <field name="procedure_id"/>
                            <field name="sequence"/>
                            <field name="name"/>
                            <field name="action_type"/>
                            <field name="delay"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_client_type_tree" model="ir.ui.view">
            <field name="name">recouvrement.client.type.tree</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <list string="Types de clients">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="procedure_id"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_client_type_form" model="ir.ui.view">
            <field name="name">recouvrement.client.type.form</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <form string="Type de client">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="code"/>
                            <field name="procedure_id"/>
                        </group>
                        <group>
                            <field name="description"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="search_recouvrement_facture" model="ir.ui.view">
            <field name="name">recouvrement.facture.search</field>
            <field name="model">recouvrement.facture</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="facture_type"/>
                    <field name="source_sheet"/>
                    <field name="recouvrement_status"/>
                    <filter name="factures_standard" string="Standard" domain="[('facture_type','=','standard')]"/>
                    <filter name="factures_proforma" string="Proforma" domain="[('facture_type','=','proforma')]"/>
                    <filter name="factures_groupement" string="Groupement" domain="[('facture_type','=','groupement')]"/>
                    <filter name="factures_avance" string="Avances" domain="[('facture_type','=','avance')]"/>
                    <filter name="factures_autre" string="Autres" domain="[('facture_type','=','autre')]"/>
                    <separator/>
                    <filter name="statut_normal" string="Normal" domain="['|', ('recouvrement_status','=','normal'), ('recouvrement_status','=',False)]"/>
                    <filter name="statut_precontentieux" string="Précontentieux" domain="[('recouvrement_status','=','precontentieux')]"/>
                    <filter name="statut_contentieux" string="Contentieux" domain="[('recouvrement_status','=','contentieux')]"/>
                    <filter name="statut_bloque" string="Bloqué" domain="[('recouvrement_status','=','bloque')]"/>
                    <filter name="statut_recouvre" string="Recouvré" domain="[('recouvrement_status','=','recouvre')]"/>
                    <separator/>
                    <filter name="feuille_groupement" string="Feuille Groupement" domain="[('source_sheet','ilike','GROUPEMENT')]"/>
                    <filter name="feuille_proforma" string="Feuille Proforma" domain="[('source_sheet','ilike','PRO-FORMA')]"/>
                    <filter name="feuille_avances" string="Feuille Avances" domain="[('source_sheet','ilike','AVANCES')]"/>
                    <separator/>
                    <filter name="group_by_type" string="Grouper par type" context="{'group_by': 'facture_type'}"/>
                    <filter name="group_by_sheet" string="Grouper par feuille" context="{'group_by': 'source_sheet'}"/>
                    <filter name="group_by_client" string="Grouper par client" context="{'group_by': 'client_id'}"/>
                </search>
            </field>
        </record>

        <record id="search_recouvrement_recouvrement" model="ir.ui.view">
            <field name="name">recouvrement.recouvrement.search</field>
            <field name="model">recouvrement.recouvrement</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="procedure_id"/>
                    <field name="phase_courante"/>
                    <field name="state"/>
                    <field name="responsable_id"/>
                    <field name="date_echeance"/>
                    <filter name="normaux" string="Normal" domain="[('state','=','draft')]"/>
                    <filter name="precontentieux" string="Précontentieux" domain="[('state','=','open')]"/>
                    <filter name="contentieux" string="Contentieux" domain="[('state','=','late')]"/>
                    <filter name="bloques" string="Bloqués" domain="[('state','=','blocked')]"/>
                    <filter name="recouvres" string="Recouvrés" domain="[('state','=','closed')]"/>
                    <separator/>
                    <filter name="group_by_procedure" string="Par procédure" context="{'group_by': 'procedure_id'}"/>
                    <filter name="group_by_phase" string="Par phase" context="{'group_by': 'phase_courante'}"/>
                    <filter name="group_by_statut" string="Par statut" context="{'group_by': 'state'}"/>
                    <filter name="group_by_responsable" string="Par responsable" context="{'group_by': 'responsable_id'}"/>
                </search>
            </field>
        </record>

        <record id="search_recouvrement_action" model="ir.ui.view">
            <field name="name">recouvrement.action.search</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="recouvrement_id"/>
                    <field name="responsible_id"/>
                    <field name="action_type"/>
                    <field name="state"/>
                    <filter name="a_faire" string="À faire" domain="[('state','=','todo')]"/>
                    <filter name="realisees" string="Réalisées" domain="[('state','=','done')]"/>
                    <filter name="aujourd_hui" string="Aujourd’hui" domain="[('mandatory_date','=', context_today())]"/>
                    <filter name="en_retard" string="En retard" domain="[('mandatory_date','&lt;', context_today()), ('state', '!=', 'done')]"/>
                    <separator/>
                    <filter name="group_by_type" string="Par type" context="{'group_by': 'action_type'}"/>
                    <filter name="group_by_responsable" string="Par responsable" context="{'group_by': 'responsible_id'}"/>
                    <filter name="group_by_statut" string="Par statut" context="{'group_by': 'state'}"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
