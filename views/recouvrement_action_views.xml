<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- ================================================================
             ACTION UNIFIÉE (appel + email + courrier + MED + contentieux)
             Champs conditionnels par action_type
        ===================================================================== -->

        <record id="view_recouvrement_action_list" model="ir.ui.view">
            <field name="name">recouvrement.action.list</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <list string="Actions"
                      decoration-warning="state=='reporte'"
                      decoration-danger="is_overdue and state in ('todo','reporte')"
                      decoration-success="state=='done'"
                      decoration-muted="state=='cancel'">
                    <field name="name"/>
                    <field name="action_type" widget="badge"/>
                    <field name="recouvrement_id"/>
                    <field name="client_id"/>
                    <field name="responsible_id"/>
                    <field name="mandatory_date"/>
                    <field name="date_done" optional="hide"/>
                    <field name="state" widget="badge"
                           decoration-success="state=='done'"
                           decoration-warning="state=='reporte'"
                           decoration-info="state=='todo'"
                           decoration-muted="state=='cancel'"/>
                    <field name="is_overdue" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_action_form" model="ir.ui.view">
            <field name="name">recouvrement.action.form</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <form string="Action">
                    <header>
                        <button name="action_done" type="object"
                                string="Marquer réalisée" class="btn-primary"
                                invisible="state == 'done'"/>
                        <button name="action_reporter" type="object"
                                string="Reporter à J+1" class="btn-warning"
                                invisible="state in ('done','cancel')"/>
                        <button name="action_envoyer_email" type="object"
                                string="Envoyer l'email" class="btn-success"
                                invisible="action_type not in ('email','courrier','mise_en_demeure') or state == 'done'"/>
                        <button name="action_planifier_outlook" type="object"
                                string="Planifier dans Outlook" class="btn-secondary"
                                invisible="not planned_datetime"/>
                        <button name="action_cancel" type="object"
                                string="Annuler" class="btn-secondary"
                                invisible="state in ('done','cancel')"/>
                        <button name="action_reset" type="object"
                                string="Réinitialiser" class="btn-secondary"
                                invisible="state == 'todo'"/>
                        <field name="state" widget="statusbar"
                               statusbar_visible="todo,done,reporte"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="Nom de l'action"/></h1>
                        </div>
                        <group>
                            <group string="Contexte">
                                <field name="recouvrement_id"/>
                                <field name="client_id"/>
                                <field name="action_template_id" readonly="1"/>
                                <field name="action_type"/>
                                <field name="priority"/>
                            </group>
                            <group string="Planification">
                                <field name="responsible_id"/>
                                <field name="mandatory_date"/>
                                <field name="date_done"/>
                                <field name="planned_datetime"/>
                                <field name="is_overdue" readonly="1"/>
                            </group>
                        </group>
                        <notebook>
                            <!-- ============== APPEL ============== -->
                            <page string="Appel" name="appel"
                                  invisible="action_type != 'appel'">
                                <group>
                                    <group>
                                        <field name="duree_minutes"/>
                                        <field name="action_prise"/>
                                    </group>
                                </group>
                                <field name="notes_appel" placeholder="Notes prises pendant l'appel"/>
                            </page>
                            <!-- ============== EMAIL / COURRIER / MED ============== -->
                            <page string="Email / Courrier" name="email"
                                  invisible="action_type not in ('email','courrier','mise_en_demeure')">
                                <group>
                                    <group>
                                        <field name="destinataire_email"/>
                                        <field name="sujet_email"/>
                                    </group>
                                    <group>
                                        <field name="email_status" readonly="1"/>
                                        <field name="date_envoi" readonly="1"/>
                                        <field name="date_lecture" readonly="1"/>
                                    </group>
                                </group>
                                <field name="corps_email"
                                       placeholder="Corps de l'email — utilisez les pièces jointes ci-dessous"/>
                                <field name="pieces_jointes_ids"
                                       widget="many2many_binary"/>
                            </page>
                            <!-- ============== COMMENTAIRE ============== -->
                            <page string="Commentaire" name="comment">
                                <field name="comment"/>
                            </page>
                            <!-- ============== OUTLOOK ============== -->
                            <page string="Synchronisation Outlook" name="outlook"
                                  invisible="not outlook_event_id and not planned_datetime">
                                <group>
                                    <field name="outlook_sync_state" readonly="1"/>
                                    <field name="outlook_web_link" widget="url"
                                           invisible="not outlook_web_link"/>
                                    <field name="outlook_event_id" readonly="1"/>
                                    <field name="outlook_sync_error" readonly="1"
                                           invisible="outlook_sync_state != 'error'"/>
                                </group>
                                <button name="action_ouvrir_outlook" type="object"
                                        string="Ouvrir dans Outlook"
                                        class="btn-link"
                                        invisible="not outlook_web_link"/>
                                <button name="action_annuler_outlook" type="object"
                                        string="Annuler la synchronisation"
                                        class="btn-link"
                                        invisible="not outlook_event_id"/>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_action_calendar" model="ir.ui.view">
            <field name="name">recouvrement.action.calendar</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <calendar string="Calendrier des actions"
                          date_start="mandatory_date"
                          color="action_type"
                          mode="month">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="action_type"/>
                    <field name="state"/>
                </calendar>
            </field>
        </record>

        <record id="view_recouvrement_action_search" model="ir.ui.view">
            <field name="name">recouvrement.action.search</field>
            <field name="model">recouvrement.action</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="recouvrement_id"/>
                    <field name="client_id"/>
                    <field name="responsible_id"/>
                    <separator/>
                    <filter name="mes_actions" string="Mes actions"
                            domain="[('responsible_id','=',uid)]"/>
                    <filter name="aujourdhui" string="Aujourd'hui"
                            domain="[('mandatory_date','=', context_today())]"/>
                    <filter name="cette_semaine" string="Cette semaine"
                            domain="[('mandatory_date','&gt;=', context_today()),
                                     ('mandatory_date','&lt;=', (context_today() + relativedelta(days=7)))]"/>
                    <filter name="en_retard" string="En retard"
                            domain="[('is_overdue','=',True),('state','in',['todo','reporte'])]"/>
                    <separator/>
                    <filter name="todo" string="À faire"
                            domain="[('state','=','todo')]"/>
                    <filter name="reporte" string="Reportées"
                            domain="[('state','=','reporte')]"/>
                    <filter name="done" string="Réalisées"
                            domain="[('state','=','done')]"/>
                    <separator/>
                    <filter name="appels" string="Appels"
                            domain="[('action_type','=','appel')]"/>
                    <filter name="emails" string="Emails"
                            domain="[('action_type','in',['email','courrier','mise_en_demeure'])]"/>
                    <separator/>
                    <filter name="group_by_state" string="Statut"
                            context="{'group_by': 'state'}"/>
                    <filter name="group_by_type" string="Type"
                            context="{'group_by': 'action_type'}"/>
                    <filter name="group_by_responsable" string="Responsable"
                            context="{'group_by': 'responsible_id'}"/>
                    <filter name="group_by_recouvrement" string="Dossier"
                            context="{'group_by': 'recouvrement_id'}"/>
                </search>
            </field>
        </record>
    </data>
</odoo>
