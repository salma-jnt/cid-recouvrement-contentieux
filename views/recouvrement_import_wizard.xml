<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_recouvrement_facture_import_wizard_form" model="ir.ui.view">
            <field name="name">recouvrement.facture.import.wizard.form</field>
            <field name="model">recouvrement.facture.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Importer des factures" class="o_rcv_import_wizard">
                    <sheet class="o_rcv_import_sheet">
                        <group>
                            <field name="file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                            <field name="sheet_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="imported_count" readonly="1"/>
                            <field name="updated_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="note" readonly="1" nolabel="1" placeholder="Le resume d'import s'affichera ici."/>
                        </group>
                        <footer>
                            <button name="action_import" type="object" string="Importer" class="btn-primary"/>
                            <button string="Fermer" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_encaissement_import_wizard_form" model="ir.ui.view">
            <field name="name">recouvrement.encaissement.import.wizard.form</field>
            <field name="model">recouvrement.encaissement.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Importer des encaissements" class="o_rcv_import_wizard">
                    <sheet class="o_rcv_import_sheet">
                        <group>
                            <field name="file" filename="file_name"/>
                            <field name="file_name" invisible="1"/>
                        </group>
                        <group>
                            <field name="imported_count" readonly="1"/>
                            <field name="updated_count" readonly="1"/>
                        </group>
                        <group>
                            <field name="note" readonly="1" nolabel="1" placeholder="Le resume d'import s'affichera ici."/>
                        </group>
                        <footer>
                            <button name="action_import" type="object" string="Importer" class="btn-primary"/>
                            <button string="Fermer" class="btn-secondary" special="cancel"/>
                        </footer>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
