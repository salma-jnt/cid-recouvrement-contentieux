<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_recouvrement_client_type_list" model="ir.ui.view">
            <field name="name">recouvrement.client.type.list</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <list string="Types de clients">
                    <field name="name"/>
                    <field name="code"/>
                    <field name="procedure_id"/>
                    <field name="active" optional="hide"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_client_type_form" model="ir.ui.view">
            <field name="name">recouvrement.client.type.form</field>
            <field name="model">recouvrement.client.type</field>
            <field name="arch" type="xml">
                <form string="Type de client">
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="name" placeholder="ex: Grands comptes"/></h1>
                            <h3><field name="code"/></h3>
                        </div>
                        <group>
                            <field name="procedure_id"/>
                            <field name="active"/>
                        </group>
                        <field name="description" placeholder="Description du type de client..."/>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
