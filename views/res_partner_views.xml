<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="view_partner_form_recouvrement_manager" model="ir.ui.view">
            <field name="name">res.partner.form.recouvrement.manager</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="mail.res_partner_view_form_inherit_mail"/>
            <field name="priority">90</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='name']" position="after">
                    <field name="client_type_id" string="Type de client Recouvrement"/>
                </xpath>
            </field>
        </record>

        <record id="view_partner_tree_recouvrement_manager" model="ir.ui.view">
            <field name="name">res.partner.tree.recouvrement.manager</field>
            <field name="model">res.partner</field>
            <field name="inherit_id" ref="mail.res_partner_view_tree_inherit_mail"/>
            <field name="priority">90</field>
            <field name="arch" type="xml">
                <xpath expr="//field[@name='phone']" position="after">
                    <field name="client_type_id" string="Type de client"/>
                </xpath>
            </field>
        </record>

        <record id="view_recouvrement_partner_list" model="ir.ui.view">
            <field name="name">res.partner.list.recouvrement</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <list string="Clients Recouvrement">
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                    <field name="country_id"/>
                    <field name="client_type_id" string="Type de client"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_partner_form" model="ir.ui.view">
            <field name="name">res.partner.form.recouvrement.simple</field>
            <field name="model">res.partner</field>
            <field name="arch" type="xml">
                <form string="Client">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                            <field name="country_id"/>
                            <field name="client_type_id" string="Type de client Recouvrement"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
