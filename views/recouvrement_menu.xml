<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <record id="action_recouvrement_facture" model="ir.actions.act_window">
            <field name="name">Factures</field>
            <field name="res_model">recouvrement.facture</field>
            <field name="view_mode">list,form</field>
            <field name="help">Importez puis suivez les factures dans le parcours de recouvrement.</field>
        </record>

        <record id="action_recouvrement_recouvrement" model="ir.actions.act_window">
            <field name="name">Dossiers de recouvrement</field>
            <field name="res_model">recouvrement.recouvrement</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_action" model="ir.actions.act_window">
            <field name="name">Actions de recouvrement</field>
            <field name="res_model">recouvrement.action</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_encaissement" model="ir.actions.act_window">
            <field name="name">Encaissements</field>
            <field name="res_model">recouvrement.encaissement</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_procedure" model="ir.actions.act_window">
            <field name="name">Procédures de recouvrement</field>
            <field name="res_model">recouvrement.procedure</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_action_template" model="ir.actions.act_window">
            <field name="name">Modèles d’actions</field>
            <field name="res_model">recouvrement.action.template</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_client_type" model="ir.actions.act_window">
            <field name="name">Types de clients</field>
            <field name="res_model">recouvrement.client.type</field>
            <field name="view_mode">list,form</field>
        </record>

        <record id="action_recouvrement_import_factures" model="ir.actions.act_window">
            <field name="name">Importer des factures</field>
            <field name="res_model">recouvrement.facture.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <record id="action_recouvrement_facture_standard" model="ir.actions.act_window">
            <field name="name">Factures standard</field>
            <field name="res_model">recouvrement.facture</field>
            <field name="view_mode">list,form</field>
            <field name="domain">['|', ('facture_type','=','standard'), '|', ('source_sheet','ilike','SUIVI DE FACTURATION'), ('source_sheet','ilike','2EME ENVOI')]</field>
        </record>

        <record id="action_recouvrement_facture_groupement" model="ir.actions.act_window">
            <field name="name">Factures groupement</field>
            <field name="res_model">recouvrement.facture</field>
            <field name="view_mode">list,form</field>
            <field name="domain">['|', ('facture_type','=','groupement'), ('source_sheet','ilike','GROUPEMENT')]</field>
        </record>

        <record id="action_recouvrement_facture_proforma" model="ir.actions.act_window">
            <field name="name">Factures proforma</field>
            <field name="res_model">recouvrement.facture</field>
            <field name="view_mode">list,form</field>
            <field name="domain">['|', ('facture_type','=','proforma'), ('source_sheet','ilike','PRO-FORMA')]</field>
        </record>

        <record id="action_recouvrement_facture_avance" model="ir.actions.act_window">
            <field name="name">Factures d'avance</field>
            <field name="res_model">recouvrement.facture</field>
            <field name="view_mode">list,form</field>
            <field name="domain">['|', ('facture_type','=','avance'), ('source_sheet','ilike','AVANCES')]</field>
        </record>

        <record id="action_recouvrement_dashboard" model="ir.actions.client">
            <field name="name">Tableau de bord Recouvrement</field>
            <field name="tag">recouvrement_contentieux.dashboard</field>
        </record>

        <record id="recouvrement_menu_root" model="ir.ui.menu">
            <field name="name">Recouvrement</field>
            <field name="sequence">10</field>
            <field name="action" ref="action_recouvrement_facture"/>
        </record>

        <record id="recouvrement_menu_facturation_section" model="ir.ui.menu">
            <field name="name">Facturation</field>
            <field name="parent_id" ref="recouvrement_menu_root"/>
            <field name="sequence">10</field>
            <field name="active">False</field>
        </record>

        <record id="recouvrement_menu_suivi_section" model="ir.ui.menu">
            <field name="name">Suivi de recouvrement</field>
            <field name="parent_id" ref="recouvrement_menu_root"/>
            <field name="sequence">20</field>
            <field name="active">False</field>
        </record>

        <record id="recouvrement_menu_parametrage" model="ir.ui.menu">
            <field name="name">Paramétrage</field>
            <field name="parent_id" ref="recouvrement_menu_root"/>
            <field name="sequence">30</field>
            <field name="active">False</field>
        </record>

        <record id="recouvrement_menu_factures" model="ir.ui.menu">
            <field name="name">Toutes les factures</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_facture"/>
            <field name="sequence">10</field>
        </record>

        <record id="recouvrement_menu_factures_standard" model="ir.ui.menu">
            <field name="name">Factures standard</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_facture_standard"/>
            <field name="sequence">20</field>
        </record>

        <record id="recouvrement_menu_factures_groupement" model="ir.ui.menu">
            <field name="name">Factures groupement</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_facture_groupement"/>
            <field name="sequence">30</field>
        </record>

        <record id="recouvrement_menu_factures_proforma" model="ir.ui.menu">
            <field name="name">Factures proforma</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_facture_proforma"/>
            <field name="sequence">40</field>
        </record>

        <record id="recouvrement_menu_factures_avance" model="ir.ui.menu">
            <field name="name">Factures d’avance</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_facture_avance"/>
            <field name="sequence">50</field>
        </record>

        <record id="recouvrement_menu_factures_import" model="ir.ui.menu">
            <field name="name">Importer des factures</field>
            <field name="parent_id" ref="recouvrement_menu_facturation_section"/>
            <field name="action" ref="action_recouvrement_import_factures"/>
            <field name="sequence">60</field>
        </record>

        <record id="recouvrement_menu_recouvrements" model="ir.ui.menu">
            <field name="name">Dossiers de recouvrement</field>
            <field name="parent_id" ref="recouvrement_menu_suivi_section"/>
            <field name="action" ref="action_recouvrement_recouvrement"/>
            <field name="sequence">10</field>
        </record>

        <record id="recouvrement_menu_actions" model="ir.ui.menu">
            <field name="name">Actions de recouvrement</field>
            <field name="parent_id" ref="recouvrement_menu_suivi_section"/>
            <field name="action" ref="action_recouvrement_action"/>
            <field name="sequence">20</field>
        </record>

        <record id="recouvrement_menu_encaissements" model="ir.ui.menu">
            <field name="name">Encaissements</field>
            <field name="parent_id" ref="recouvrement_menu_suivi_section"/>
            <field name="action" ref="action_recouvrement_encaissement"/>
            <field name="sequence">30</field>
        </record>

        <record id="recouvrement_menu_parametrage_procedures" model="ir.ui.menu">
            <field name="name">Procédures de recouvrement</field>
            <field name="parent_id" ref="recouvrement_menu_parametrage"/>
            <field name="action" ref="action_recouvrement_procedure"/>
            <field name="sequence">10</field>
        </record>

        <record id="recouvrement_menu_parametrage_action_templates" model="ir.ui.menu">
            <field name="name">Modèles d’actions</field>
            <field name="parent_id" ref="recouvrement_menu_parametrage"/>
            <field name="action" ref="action_recouvrement_action_template"/>
            <field name="sequence">20</field>
        </record>

        <record id="recouvrement_menu_parametrage_client_types" model="ir.ui.menu">
            <field name="name">Types de clients</field>
            <field name="parent_id" ref="recouvrement_menu_parametrage"/>
            <field name="action" ref="action_recouvrement_client_type"/>
            <field name="sequence">30</field>
        </record>
    </data>
</odoo>
