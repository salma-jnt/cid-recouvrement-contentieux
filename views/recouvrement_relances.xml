<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <data>
        <!-- APPELS DE RELANCE -->
        <record id="view_recouvrement_appel_list" model="ir.ui.view">
            <field name="name">recouvrement.appel.list</field>
            <field name="model">recouvrement.appel</field>
            <field name="arch" type="xml">
                <list string="Appels de relance">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="date_appel"/>
                    <field name="statut"/>
                    <field name="action_prise"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_appel_form" model="ir.ui.view">
            <field name="name">recouvrement.appel.form</field>
            <field name="model">recouvrement.appel</field>
            <field name="arch" type="xml">
                <form string="Appel de relance">
                    <header>
                        <button name="action_marquer_realise" string="Marquer comme réalisé" type="object" class="oe_highlight" invisible="statut != 'brouillon'"/>
                        <button name="action_marquer_non_joignable" string="Non joignable" type="object" invisible="statut != 'brouillon'"/>
                        <button name="action_planifier_rappel" string="Planifier rappel" type="object" invisible="not ((statut == 'non_joignable') or (statut == 'rappel_needed'))"/>
                        <button name="action_planifier_outlook" string="Planifier dans Outlook" type="object" class="btn-primary"/>
                        <button name="action_annuler_outlook" string="Annuler Outlook" type="object" invisible="not outlook_event_id"/>
                        <button name="action_ouvrir_outlook" string="Ouvrir dans Outlook" type="object" invisible="not outlook_web_link"/>
                        <field name="statut" widget="statusbar" options="{'clickable': False}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="facture_id"/>
                                <field name="client_id" readonly="1"/>
                                <field name="date_appel"/>
                                <field name="planned_datetime"/>
                            </group>
                            <group>
                                <field name="responsable_id"/>
                                <field name="action_template_id" options="{'no_create_edit': True}"/>
                                <field name="duree_minutes"/>
                                <field name="action_prise"/>
                                <field name="date_prochain_appel"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="outlook_sync_state" readonly="1"/>
                                <field name="outlook_event_id" readonly="1"/>
                                <field name="outlook_web_link" readonly="1" widget="url"/>
                            </group>
                            <group>
                                <field name="outlook_sync_error" readonly="1" invisible="outlook_sync_state != 'error'"/>
                            </group>
                        </group>
                        <group>
                            <field name="notes" nolabel="1" placeholder="Notes de l'appel..."/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_appel_search" model="ir.ui.view">
            <field name="name">recouvrement.appel.search</field>
            <field name="model">recouvrement.appel</field>
            <field name="arch" type="xml">
                <search string="Appels de relance">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="responsable_id"/>
                    <filter string="Brouillon" name="brouillon" domain="[('statut', '=', 'brouillon')]"/>
                    <filter string="Réalisés" name="realises" domain="[('statut', '=', 'realise')]"/>
                    <filter string="Non joignable" name="non_joignable" domain="[('statut', '=', 'non_joignable')]"/>
                    <filter string="À faire" name="a_faire" domain="[('statut', 'in', ['brouillon', 'rappel_needed'])]"/>
                </search>
            </field>
        </record>

        <record id="view_recouvrement_appel_calendar" model="ir.ui.view">
            <field name="name">recouvrement.appel.calendar</field>
            <field name="model">recouvrement.appel</field>
            <field name="arch" type="xml">
                <calendar string="Calendrier des relances" date_start="date_appel" color="responsable_id" mode="week">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="statut"/>
                    <field name="responsable_id"/>
                </calendar>
            </field>
        </record>

        <record id="action_recouvrement_appel" model="ir.actions.act_window">
            <field name="name">Appels de relance</field>
            <field name="res_model">recouvrement.appel</field>
            <field name="view_mode">list,form</field>
            <field name="help">Gérez les appels de relance auprès des clients.</field>
        </record>

        <record id="action_recouvrement_appel_calendar" model="ir.actions.act_window">
            <field name="name">Calendrier des relances</field>
            <field name="res_model">recouvrement.appel</field>
            <field name="view_mode">calendar,list,form</field>
            <field name="help">Planifiez et suivez les appels de relance dans un calendrier.</field>
        </record>

        <!-- EMAILS DE RELANCE -->
        <record id="view_recouvrement_email_list" model="ir.ui.view">
            <field name="name">recouvrement.email.list</field>
            <field name="model">recouvrement.email</field>
            <field name="arch" type="xml">
                <list string="Emails de relance">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="destinataire_email"/>
                    <field name="date_email"/>
                    <field name="statut"/>
                </list>
            </field>
        </record>

        <record id="view_recouvrement_email_form" model="ir.ui.view">
            <field name="name">recouvrement.email.form</field>
            <field name="model">recouvrement.email</field>
            <field name="arch" type="xml">
                <form string="Email de relance">
                    <header>
                        <button name="action_envoyer_brouillon" string="Envoyer l'email" type="object" class="oe_highlight" invisible="statut != 'brouillon'"/>
                        <button name="action_marquer_lu" string="Marquer comme lu" type="object" invisible="statut != 'envoye'"/>
                        <button name="action_ajouter_reponse" string="Ajouter réponse" type="object" invisible="not ((statut == 'lu') or (statut == 'reponse'))"/>
                        <button name="action_planifier_outlook" string="Planifier dans Outlook" type="object" class="btn-primary"/>
                        <button name="action_annuler_outlook" string="Annuler Outlook" type="object" invisible="not outlook_event_id"/>
                        <button name="action_ouvrir_outlook" string="Ouvrir dans Outlook" type="object" invisible="not outlook_web_link"/>
                        <field name="statut" widget="statusbar" options="{'clickable': False}"/>
                    </header>
                    <sheet>
                        <group>
                            <group>
                                <field name="name"/>
                                <field name="facture_id"/>
                                <field name="client_id" readonly="1"/>
                                <field name="procedure_id" invisible="1"/>
                                <field name="destinataire_email"/>
                                <field name="date_email"/>
                                <field name="planned_datetime"/>
                            </group>
                            <group>
                                <field name="responsable_id"/>
                                <field name="action_template_id" options="{'no_create_edit': True}"/>
                                <field name="date_lecture"/>
                                <field name="date_reponse"/>
                            </group>
                        </group>
                        <group>
                            <group>
                                <field name="outlook_sync_state" readonly="1"/>
                                <field name="outlook_event_id" readonly="1"/>
                                <field name="outlook_web_link" readonly="1" widget="url"/>
                            </group>
                            <group>
                                <field name="outlook_sync_error" readonly="1" invisible="outlook_sync_state != 'error'"/>
                            </group>
                        </group>
                        <group>
                            <field name="corps_email" nolabel="1" placeholder="Contenu de l'email..."/>
                        </group>
                        <group>
                            <field name="contenu_reponse" placeholder="Réponse reçue..." nolabel="1"/>
                        </group>
                        <group>
                            <field name="pieces_jointes_ids" nolabel="1" widget="many2many_binary"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_recouvrement_email_search" model="ir.ui.view">
            <field name="name">recouvrement.email.search</field>
            <field name="model">recouvrement.email</field>
            <field name="arch" type="xml">
                <search string="Emails de relance">
                    <field name="name"/>
                    <field name="client_id"/>
                    <field name="destinataire_email"/>
                    <field name="responsable_id"/>
                    <filter string="Brouillon" name="brouillon" domain="[('statut', '=', 'brouillon')]"/>
                    <filter string="Envoyés" name="envoyes" domain="[('statut', '=', 'envoye')]"/>
                    <filter string="Lus" name="lus" domain="[('statut', '=', 'lu')]"/>
                    <filter string="Réponse reçue" name="reponse" domain="[('statut', '=', 'reponse')]"/>
                    <filter string="Erreur" name="erreur" domain="[('statut', '=', 'erreur')]"/>
                    <filter string="À envoyer" name="a_envoyer" domain="[('statut', '=', 'brouillon')]"/>
                </search>
            </field>
        </record>

        <record id="action_recouvrement_email" model="ir.actions.act_window">
            <field name="name">Emails de relance</field>
            <field name="res_model">recouvrement.email</field>
            <field name="view_mode">list,form</field>
            <field name="help">Gérez les emails de relance auprès des clients.</field>
        </record>
    </data>
</odoo>
